<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="20dp">

    <!-- Tiêu đề --> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📚 HỌC TỪ VỰNG TOEIC" android:textSize="28sp" android:textStyle="bold" android:textColor="#3F51B5"/> <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚗 Chủ đề: Vehicles" android:textSize="20sp" android:textStyle="bold" android:textColor="#2196F3" android:layout_marginTop="10dp" android:layout_marginBottom="20dp"/>
    <ImageView
        android:id="@+id/imgWord"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:src="@drawable/chicken"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/txtEnglish"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chicken"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnMeaning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xem nghĩa"
        android:layout_marginTop="40dp" />

    <TextView
        android:id="@+id/txtMeaning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="25sp"
        android:visibility="gone"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tiếp theo"
        android:layout_marginTop="30dp" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" Đổi chủ đề"
        android:layout_marginTop="20dp" />

</LinearLayout>